    <Placemark>
      <name>Abstract Expressionism</name>
      <description><![CDATA[<b>Abstract Expressionism</b><br><i>Arts &amp; Culture</i><br>Fri 6th Mar – Fri 17th Apr<br>Tate Modern, Bankside<br>£22<br><br>Major survey of Abstract Expressionism spanning six decades of American painting at Tate Modern.<br><br><a href="https://www.tate.org.uk/whats-on/tate-modern/abstract-expressionism">More info / tickets</a>]]></description>
      <styleUrl>#orange-dot.png</styleUrl>
      <Point>
        <coordinates>-0.09934164882888792,51.5074293,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Open Mic Night</name>
      <description><![CDATA[<b>Open Mic Night</b><br><i>Music</i><br>Fri 20th Mar<br>The Lexington, Islington<br>Free<br><br>Open stage for singers, comedians, and spoken word artists at The Lexington.<br><br><a href="https://www.thelexington.co.uk/open-mic">More info / tickets</a>]]></description>
